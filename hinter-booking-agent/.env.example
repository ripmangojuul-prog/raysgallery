# ─────────────────────────────────────────────────────────────────────────────
# HINTER booking agent — environment
# Copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Brain (xAI / Grok) ──────────────────────────────────────────────────────
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Grok 4.2 reasoning (pinned snapshot). Use grok-4.20-reasoning for the rolling
# stable alias, or grok-4.3 for xAI's newest flagship.
XAI_MODEL=grok-4.20-0309-reasoning
# Reasoning tokens count against the output cap; keep it generous so short replies
# never truncate. (Default 8000.)
# XAI_MAX_TOKENS=8000

# ── Firestore (gcloud) ──────────────────────────────────────────────────────
# Path to a Firebase/GCP service-account JSON with Firestore access.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIRESTORE_PROJECT_ID=your-gcloud-project-id

# ── Google Calendar (rscatchings@gmail.com) ─────────────────────────────────
# OAuth desktop client (create in Google Cloud Console → Credentials).
GCAL_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GCAL_CLIENT_SECRET=xxxxxxxxxxxxxxxx
# Produced by `npm run get-token` (one-time consent). Acts AS Ray's account.
GCAL_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxx
GCAL_CALENDAR_ID=rscatchings@gmail.com

# ── Google Voice bridge (Playwright) ────────────────────────────────────────
# Folder where the logged-in Google Voice browser session is persisted.
GV_AUTH_DIR=./.gv-auth
# Set HEADLESS=false the first few runs so you can watch it work.
GV_HEADLESS=true
# How often to check for new inbound texts (ms). 15s is a good balance.
GV_POLL_INTERVAL_MS=15000

# ── Owner / handoff ─────────────────────────────────────────────────────────
# Ray's personal cell (NOT the Google Voice booking line) for handoff pings &
# the one-tap Zelle deposit confirmation. The bot texts THIS number via the
# same Google Voice line.
OWNER_NAME=Ray
OWNER_PHONE=+1XXXXXXXXXX

# ── Misc ────────────────────────────────────────────────────────────────────
# DRY_RUN=true logs replies instead of sending them — use while testing.
DRY_RUN=false
LOG_LEVEL=info
